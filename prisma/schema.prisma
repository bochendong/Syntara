generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoursePurpose {
  research
  university
  daily
}

enum ConversationKind {
  notebook
  agent
  system
}

enum AgentTaskStatus {
  queued
  running
  waiting
  completed
  failed
  cancelled
}

enum AgentEnvelopeType {
  task_dispatch
  task_ack
  task_wait
  task_partial
  task_result
  task_error
}

enum UserRole {
  USER
  ADMIN
}

enum CreditTransactionKind {
  WELCOME_BONUS
  COURSE_PURCHASE
  NOTEBOOK_PURCHASE
  CREATOR_COURSE_SALE
  CREATOR_NOTEBOOK_SALE
  TOKEN_USAGE
  CASH_TO_COMPUTE_TRANSFER
  CASH_TO_PURCHASE_TRANSFER
  LESSON_REWARD
  QUIZ_COMPLETION_REWARD
  QUIZ_ACCURACY_BONUS
  REVIEW_REWARD
  DAILY_TASK_REWARD
  STREAK_BONUS
  CHARACTER_UNLOCK_SPEND
  AVATAR_UNLOCK_SPEND
  GACHA_DRAW_SPEND
  /// @deprecated Kept for backward compatibility — existing rows in the database still reference this value
  NOTEBOOK_GENERATION_USAGE
}

enum CreditAccountType {
  CASH
  COMPUTE
  PURCHASE
  /// @deprecated Kept for backward compatibility — existing rows in the database still reference this value
  NOTEBOOK_GENERATION
}

enum TopUpOrderStatus {
  pending
  fulfilled
  expired
}

enum CharacterAssetType {
  LIVE2D
  AVATAR
}

enum LearningActionType {
  DAILY_SIGN_IN
  LESSON_MILESTONE_COMPLETED
  QUIZ_COMPLETED
  QUIZ_ACCURACY_BONUS
  REVIEW_COMPLETED
  DAILY_TASK_REWARD
  STREAK_BONUS
  CHARACTER_UNLOCK
  AVATAR_UNLOCK
  CHARACTER_EQUIP
  GACHA_DRAW
}

enum MissionType {
  DAILY_SIGN_IN
  DAILY_LESSON
  DAILY_QUIZ
  DAILY_REVIEW
  DAILY_ALL_CLEAR
  WEEKLY_STUDY_DAYS
  WEEKLY_QUIZ_BATCHES
}

enum NotebookProblemType {
  short_answer
  choice
  proof
  calculation
  code
  fill_blank
}

enum NotebookProblemStatus {
  draft
  published
  archived
}

enum NotebookProblemSource {
  chat
  pdf
  manual
  web
  legacy_quiz_scene
}

enum NotebookProblemDifficulty {
  easy
  medium
  hard
}

enum NotebookProblemAttemptKind {
  run
  submit
  answer
}

enum NotebookProblemAttemptStatus {
  pending
  passed
  failed
  partial
  error
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  role                   UserRole  @default(USER)
  creditsBalance         Int       @default(0)
  computeCreditsBalance  Int       @default(0)
  purchaseCreditsBalance Int       @default(0)
  stripeCustomerId       String?   @unique

  accounts Account[]
  sessions Session[]

  courses                 Course[]
  notebooks               Notebook[]
  conversations           Conversation[]
  messages                Message[]
  agentTasks              AgentTask[]
  agentEnvelopes          AgentEnvelope[]
  llmUsageLogs            LLMUsageLog[]
  creditTransactions      CreditTransaction[]
  coursePurchases         CoursePurchase[]
  notebookPurchases       NotebookPurchase[]
  courseReviews           CourseReview[]
  notebookReviews         NotebookReview[]
  notebookProblemAttempts NotebookProblemAttempt[]
  topUpOrders             TopUpOrder[]
  engagementProfile       UserEngagementProfile?
  learningActionLogs      LearningActionLog[]
  characterProgress       UserCharacterProgress[]
  missionProgress         UserMissionProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id                  String        @id @default(cuid())
  ownerId             String
  name                String
  description         String?
  language            String        @default("zh-CN")
  tags                String[]
  purpose             CoursePurpose @default(daily)
  university          String?
  courseCode          String?
  avatarUrl           String?
  /**
   * 开启后出现在「课程商城」社区列表
   */
  listedInCourseStore Boolean       @default(false)
  coursePriceCents    Int           @default(0)
  storePublishedAt    DateTime?
  sourceCourseId      String?

  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notebooks       Notebook[]
  problems        NotebookProblem[]
  conversations   Conversation[]
  agentTasks      AgentTask[]
  sourcePurchases CoursePurchase[]  @relation("CoursePurchaseSource")
  clonePurchase   CoursePurchase?   @relation("CoursePurchaseClone")
  reviews         CourseReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([listedInCourseStore, updatedAt(sort: Desc)])
}

model Notebook {
  id                    String    @id @default(cuid())
  ownerId               String
  courseId              String?
  name                  String
  description           String?
  tags                  String[]
  avatarUrl             String?
  language              String?
  style                 String?
  listedInNotebookStore Boolean   @default(false)
  notebookPriceCents    Int       @default(0)
  storePublishedAt      DateTime?
  sourceNotebookId      String?

  owner           User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course          Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  scenes          Scene[]
  problems        NotebookProblem[]
  conversations   Conversation[]
  agentTasks      AgentTask[]
  sourcePurchases NotebookPurchase[] @relation("NotebookPurchaseSource")
  clonePurchase   NotebookPurchase?  @relation("NotebookPurchaseClone")
  reviews         NotebookReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([listedInNotebookStore, updatedAt(sort: Desc)])
}

model Scene {
  id         String @id @default(cuid())
  notebookId String
  title      String
  type       String
  order      Int
  content    Json
  actions    Json?
  whiteboard Json?

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([notebookId, order])
}

model NotebookProblem {
  id                String                    @id @default(cuid())
  courseId          String?
  notebookId        String?
  title             String
  type              NotebookProblemType
  status            NotebookProblemStatus     @default(draft)
  source            NotebookProblemSource     @default(manual)
  order             Int
  points            Int                       @default(1)
  tags              String[]
  difficulty        NotebookProblemDifficulty @default(medium)
  publicContentJson Json
  gradingJson       Json
  sourceMeta        Json?

  course   Course?                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  notebook Notebook?                @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  secret   NotebookProblemSecret?
  attempts NotebookProblemAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
  @@index([courseId, status, order])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, order])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model NotebookProblemSecret {
  problemId       String @id
  secretJudgeJson Json

  problem NotebookProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotebookProblemAttempt {
  id         String                       @id @default(cuid())
  problemId  String
  userId     String
  kind       NotebookProblemAttemptKind
  answerJson Json
  resultJson Json?
  score      Float?
  status     NotebookProblemAttemptStatus @default(pending)

  problem NotebookProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([problemId, createdAt(sort: Desc)])
  @@index([problemId, userId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Conversation {
  id         String           @id @default(cuid())
  ownerId    String
  courseId   String?
  notebookId String?
  kind       ConversationKind
  targetId   String?
  title      String?
  meta       Json?

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model Message {
  id             String  @id @default(cuid())
  conversationId String
  ownerId        String
  role           String
  senderAgentId  String?
  targetAgentId  String?
  content        Json
  plainText      String?
  meta           Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model AgentTask {
  id            String          @id @default(cuid())
  ownerId       String
  courseId      String?
  notebookId    String?
  sourceAgentId String?
  targetAgentId String?
  taskType      String
  status        AgentTaskStatus @default(queued)
  request       Json?
  result        Json?
  error         String?

  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course    Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook  Notebook?       @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  envelopes AgentEnvelope[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model AgentEnvelope {
  id           String            @id @default(cuid())
  taskId       String
  ownerId      String
  fromAgentId  String?
  toAgentId    String?
  envelopeType AgentEnvelopeType
  payload      Json

  task  AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model SystemLLMConfig {
  id         String   @id @default("default")
  providerId String   @default("openai")
  modelId    String   @default("gpt-4o-mini")
  apiKey     String   @db.Text
  baseUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LLMUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  userName     String?
  route        String
  source       String
  providerId   String
  modelId      String
  modelString  String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([route, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model CoursePurchase {
  id             String   @id @default(cuid())
  buyerId        String
  sourceCourseId String
  clonedCourseId String   @unique
  priceCents     Int      @default(0)
  createdAt      DateTime @default(now())

  buyer        User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sourceCourse Course @relation("CoursePurchaseSource", fields: [sourceCourseId], references: [id], onDelete: Cascade)
  clonedCourse Course @relation("CoursePurchaseClone", fields: [clonedCourseId], references: [id], onDelete: Cascade)

  @@unique([buyerId, sourceCourseId])
  @@index([buyerId, createdAt(sort: Desc)])
}

model NotebookPurchase {
  id               String   @id @default(cuid())
  buyerId          String
  sourceNotebookId String
  clonedNotebookId String   @unique
  priceCents       Int      @default(0)
  createdAt        DateTime @default(now())

  buyer          User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sourceNotebook Notebook @relation("NotebookPurchaseSource", fields: [sourceNotebookId], references: [id], onDelete: Cascade)
  clonedNotebook Notebook @relation("NotebookPurchaseClone", fields: [clonedNotebookId], references: [id], onDelete: Cascade)

  @@unique([buyerId, sourceNotebookId])
  @@index([buyerId, createdAt(sort: Desc)])
}

model CourseReview {
  id         String   @id @default(cuid())
  courseId   String
  reviewerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([courseId, reviewerId])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
}

model CreditTransaction {
  id            String                @id @default(cuid())
  userId        String
  kind          CreditTransactionKind
  accountType   CreditAccountType     @default(CASH)
  delta         Int
  balanceAfter  Int
  description   String?
  referenceType String?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
}

model UserEngagementProfile {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  streakDays                 Int       @default(0)
  lastStudyAt                DateTime?
  todayEarnedPurchaseCredits Int       @default(0)
  preferredCharacterId       String?
  avatarInventory            Json?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([preferredCharacterId])
}

model LearningActionLog {
  id                      String             @id @default(cuid())
  userId                  String
  actionType              LearningActionType
  courseId                String?
  sceneId                 String?
  metadata                Json?
  rewardedPurchaseCredits Int                @default(0)
  rewardedAffinity        Int                @default(0)
  createdAt               DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([sceneId, createdAt(sort: Desc)])
}

model CharacterCatalog {
  id                        String             @id
  name                      String
  assetType                 CharacterAssetType
  unlockCostPurchaseCredits Int                @default(0)
  affinityLevelRequired     Int                @default(1)
  sortOrder                 Int                @default(0)
  isDefault                 Boolean            @default(false)
  metadata                  Json?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  userProgress UserCharacterProgress[]

  @@index([assetType, sortOrder])
}

model UserCharacterProgress {
  id            String    @id @default(cuid())
  userId        String
  characterId   String
  isUnlocked    Boolean   @default(false)
  fragmentCount Int       @default(0)
  affinityExp   Int       @default(0)
  affinityLevel Int       @default(1)
  equippedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  character CharacterCatalog @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId, equippedAt(sort: Desc)])
}

model UserMissionProgress {
  id            String      @id @default(cuid())
  userId        String
  missionType   MissionType
  periodKey     String
  targetValue   Int
  progressValue Int         @default(0)
  claimedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionType, periodKey])
  @@index([userId, periodKey])
}

model CreditTopUpPrice {
  id              String   @id @default(cuid())
  packId          String
  currency        String
  credits         Int
  unitAmount      Int
  stripeProductId String
  stripePriceId   String   @unique
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([packId, currency])
  @@index([stripeProductId])
}

model TopUpOrder {
  id                      String           @id @default(cuid())
  userId                  String
  packId                  String
  packTitle               String
  credits                 Int
  currency                String
  amountTotal             Int
  stripeCustomerId        String?
  stripeProductId         String?
  stripePriceId           String?
  stripeCheckoutSessionId String?          @unique
  stripePaymentIntentId   String?          @unique
  status                  TopUpOrderStatus @default(pending)
  fulfilledAt             DateTime?
  metadata                Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  createdAt     DateTime @default(now())

  @@index([eventType, createdAt(sort: Desc)])
}

model NotebookReview {
  id         String   @id @default(cuid())
  notebookId String
  reviewerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([notebookId, reviewerId])
  @@index([notebookId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
}
