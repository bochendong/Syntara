generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoursePurpose {
  research
  university
  daily
}

enum ConversationKind {
  notebook
  agent
  system
}

enum AgentTaskStatus {
  queued
  running
  waiting
  completed
  failed
  cancelled
}

enum AgentEnvelopeType {
  task_dispatch
  task_ack
  task_wait
  task_partial
  task_result
  task_error
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]

  courses       Course[]
  notebooks     Notebook[]
  conversations Conversation[]
  messages      Message[]
  agentTasks    AgentTask[]
  agentEnvelopes AgentEnvelope[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id          String        @id @default(cuid())
  ownerId     String
  name        String
  description String?
  language    String        @default("zh-CN")
  tags        String[]
  purpose     CoursePurpose @default(daily)
  university  String?
  courseCode  String?
  avatarUrl   String?

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notebooks     Notebook[]
  conversations Conversation[]
  agentTasks    AgentTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
}

model Notebook {
  id          String   @id @default(cuid())
  ownerId     String
  courseId    String?
  name        String
  description String?
  tags        String[]
  avatarUrl   String?
  language    String?
  style       String?

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course        Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  scenes        Scene[]
  conversations Conversation[]
  agentTasks    AgentTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
}

model Scene {
  id         String @id @default(cuid())
  notebookId String
  title      String
  type       String
  order      Int
  content    Json
  actions    Json?
  whiteboard Json?

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([notebookId, order])
}

model Conversation {
  id         String           @id @default(cuid())
  ownerId    String
  courseId   String?
  notebookId String?
  kind       ConversationKind
  targetId   String?
  title      String?
  meta       Json?

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model Message {
  id             String @id @default(cuid())
  conversationId String
  ownerId        String
  role           String
  senderAgentId  String?
  targetAgentId  String?
  content        Json
  plainText      String?
  meta           Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model AgentTask {
  id            String          @id @default(cuid())
  ownerId       String
  courseId      String?
  notebookId    String?
  sourceAgentId String?
  targetAgentId String?
  taskType      String
  status        AgentTaskStatus @default(queued)
  request       Json?
  result        Json?
  error         String?

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook  Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  envelopes AgentEnvelope[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model AgentEnvelope {
  id          String            @id @default(cuid())
  taskId       String
  ownerId      String
  fromAgentId  String?
  toAgentId    String?
  envelopeType AgentEnvelopeType
  payload      Json

  task  AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}
