generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoursePurpose {
  research
  university
  daily
}

enum ConversationKind {
  notebook
  agent
  system
}

enum AgentTaskStatus {
  queued
  running
  waiting
  completed
  failed
  cancelled
}

enum AgentEnvelopeType {
  task_dispatch
  task_ack
  task_wait
  task_partial
  task_result
  task_error
}

enum UserRole {
  USER
  ADMIN
}

enum CreditTransactionKind {
  WELCOME_BONUS
  COURSE_PURCHASE
  NOTEBOOK_PURCHASE
  CREATOR_COURSE_SALE
  CREATOR_NOTEBOOK_SALE
  TOKEN_USAGE
  CASH_TO_COMPUTE_TRANSFER
  CASH_TO_PURCHASE_TRANSFER
  /// @deprecated Kept for backward compatibility — existing rows in the database still reference this value
  NOTEBOOK_GENERATION_USAGE
}

enum CreditAccountType {
  CASH
  COMPUTE
  PURCHASE
  /// @deprecated Kept for backward compatibility — existing rows in the database still reference this value
  NOTEBOOK_GENERATION
}

enum TopUpOrderStatus {
  pending
  fulfilled
  expired
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  role             UserRole  @default(USER)
  creditsBalance   Int       @default(0)
  computeCreditsBalance Int  @default(0)
  purchaseCreditsBalance Int @default(0)
  stripeCustomerId String?   @unique

  accounts Account[]
  sessions Session[]

  courses            Course[]
  notebooks          Notebook[]
  conversations      Conversation[]
  messages           Message[]
  agentTasks         AgentTask[]
  agentEnvelopes     AgentEnvelope[]
  llmUsageLogs       LLMUsageLog[]
  creditTransactions CreditTransaction[]
  coursePurchases    CoursePurchase[]
  notebookPurchases  NotebookPurchase[]
  courseReviews      CourseReview[]
  notebookReviews    NotebookReview[]
  topUpOrders        TopUpOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id                  String        @id @default(cuid())
  ownerId             String
  name                String
  description         String?
  language            String        @default("zh-CN")
  tags                String[]
  purpose             CoursePurpose @default(daily)
  university          String?
  courseCode          String?
  avatarUrl           String?
  /**
   * 开启后出现在「课程商城」社区列表
   */
  listedInCourseStore Boolean       @default(false)
  coursePriceCents    Int           @default(0)
  storePublishedAt    DateTime?
  sourceCourseId      String?

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notebooks       Notebook[]
  conversations   Conversation[]
  agentTasks      AgentTask[]
  sourcePurchases CoursePurchase[] @relation("CoursePurchaseSource")
  clonePurchase   CoursePurchase?  @relation("CoursePurchaseClone")
  reviews         CourseReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([listedInCourseStore, updatedAt(sort: Desc)])
}

model Notebook {
  id                    String    @id @default(cuid())
  ownerId               String
  courseId              String?
  name                  String
  description           String?
  tags                  String[]
  avatarUrl             String?
  language              String?
  style                 String?
  listedInNotebookStore Boolean   @default(false)
  notebookPriceCents    Int       @default(0)
  storePublishedAt      DateTime?
  sourceNotebookId      String?

  owner           User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course          Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  scenes          Scene[]
  conversations   Conversation[]
  agentTasks      AgentTask[]
  sourcePurchases NotebookPurchase[] @relation("NotebookPurchaseSource")
  clonePurchase   NotebookPurchase?  @relation("NotebookPurchaseClone")
  reviews         NotebookReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([listedInNotebookStore, updatedAt(sort: Desc)])
}

model Scene {
  id         String @id @default(cuid())
  notebookId String
  title      String
  type       String
  order      Int
  content    Json
  actions    Json?
  whiteboard Json?

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([notebookId, order])
}

model Conversation {
  id         String           @id @default(cuid())
  ownerId    String
  courseId   String?
  notebookId String?
  kind       ConversationKind
  targetId   String?
  title      String?
  meta       Json?

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model Message {
  id             String  @id @default(cuid())
  conversationId String
  ownerId        String
  role           String
  senderAgentId  String?
  targetAgentId  String?
  content        Json
  plainText      String?
  meta           Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model AgentTask {
  id            String          @id @default(cuid())
  ownerId       String
  courseId      String?
  notebookId    String?
  sourceAgentId String?
  targetAgentId String?
  taskType      String
  status        AgentTaskStatus @default(queued)
  request       Json?
  result        Json?
  error         String?

  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course    Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  notebook  Notebook?       @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  envelopes AgentEnvelope[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([courseId, updatedAt(sort: Desc)])
  @@index([notebookId, updatedAt(sort: Desc)])
}

model AgentEnvelope {
  id           String            @id @default(cuid())
  taskId       String
  ownerId      String
  fromAgentId  String?
  toAgentId    String?
  envelopeType AgentEnvelopeType
  payload      Json

  task  AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId, createdAt(sort: Asc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model SystemLLMConfig {
  id         String   @id @default("default")
  providerId String   @default("openai")
  modelId    String   @default("gpt-4o-mini")
  apiKey     String   @db.Text
  baseUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LLMUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  userName     String?
  route        String
  source       String
  providerId   String
  modelId      String
  modelString  String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([route, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model CoursePurchase {
  id             String   @id @default(cuid())
  buyerId        String
  sourceCourseId String
  clonedCourseId String   @unique
  priceCents     Int      @default(0)
  createdAt      DateTime @default(now())

  buyer        User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sourceCourse Course @relation("CoursePurchaseSource", fields: [sourceCourseId], references: [id], onDelete: Cascade)
  clonedCourse Course @relation("CoursePurchaseClone", fields: [clonedCourseId], references: [id], onDelete: Cascade)

  @@unique([buyerId, sourceCourseId])
  @@index([buyerId, createdAt(sort: Desc)])
}

model NotebookPurchase {
  id               String   @id @default(cuid())
  buyerId          String
  sourceNotebookId String
  clonedNotebookId String   @unique
  priceCents       Int      @default(0)
  createdAt        DateTime @default(now())

  buyer          User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sourceNotebook Notebook @relation("NotebookPurchaseSource", fields: [sourceNotebookId], references: [id], onDelete: Cascade)
  clonedNotebook Notebook @relation("NotebookPurchaseClone", fields: [clonedNotebookId], references: [id], onDelete: Cascade)

  @@unique([buyerId, sourceNotebookId])
  @@index([buyerId, createdAt(sort: Desc)])
}

model CourseReview {
  id         String   @id @default(cuid())
  courseId   String
  reviewerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([courseId, reviewerId])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
}

model CreditTransaction {
  id            String                @id @default(cuid())
  userId        String
  kind          CreditTransactionKind
  accountType   CreditAccountType     @default(CASH)
  delta         Int
  balanceAfter  Int
  description   String?
  referenceType String?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
}

model CreditTopUpPrice {
  id              String   @id @default(cuid())
  packId          String
  currency        String
  credits         Int
  unitAmount      Int
  stripeProductId String
  stripePriceId   String   @unique
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([packId, currency])
  @@index([stripeProductId])
}

model TopUpOrder {
  id                      String           @id @default(cuid())
  userId                  String
  packId                  String
  packTitle               String
  credits                 Int
  currency                String
  amountTotal             Int
  stripeCustomerId        String?
  stripeProductId         String?
  stripePriceId           String?
  stripeCheckoutSessionId String?          @unique
  stripePaymentIntentId   String?          @unique
  status                  TopUpOrderStatus @default(pending)
  fulfilledAt             DateTime?
  metadata                Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  createdAt     DateTime @default(now())

  @@index([eventType, createdAt(sort: Desc)])
}

model NotebookReview {
  id         String   @id @default(cuid())
  notebookId String
  reviewerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([notebookId, reviewerId])
  @@index([notebookId, createdAt(sort: Desc)])
  @@index([reviewerId, createdAt(sort: Desc)])
}
